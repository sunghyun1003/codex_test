# OpenAI
OPENAI_API_KEY=
ENABLE_OPENAI_REPORT=false
OPENAI_TEXT_MODEL=gpt-5.2
OPENAI_IMAGE_MODEL=gpt-image-1.5
OPENAI_IMAGE_SIZE=1024x1536
GENERATE_IMAGES=false
COMPOSE_FINAL_BANNERS=false
GENERATE_REPORT_DOCX=true
GENERATE_REPORT_HTML=true
SEND_ONLY_IF_VALIDATION_PASSES=true
ENABLE_LLM_VALIDATION=false

# Trend source APIs
YOUTUBE_API_KEY=
ENABLE_YOUTUBE=true
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
ENABLE_NAVER_DATALAB=true

# Email delivery
SEND_EMAIL=false
EMAIL_DRY_RUN=true
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=sunghyun1003@gmail.com
SMTP_PASSWORD=
EMAIL_FROM=sunghyun1003@gmail.com
EMAIL_TO=sunghyun.yang@hanwha.com,sunghyun1003@naver.com
EMAIL_SUBJECT_PREFIX=[Weekly Trend]

# Runtime
TIMEZONE=Asia/Seoul
OUTPUT_DIR=outputs
SOURCE_CONFIG=config/sources.json
MAX_ITEMS_PER_SOURCE=12
FETCH_TIMEOUT_SECONDS=12
